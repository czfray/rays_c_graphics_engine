{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "buildappdb",
      "type": "shell",
      "command": "make app_debug",
      "options": {
        "cwd": "${workspaceFolder}/cmake"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },

    {
      "label": "buildappdb+rgce",
      "type": "shell",
      "command": "echo \"Building...\"",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "dependsOn": [
        "buildrcge",
        "buildappdb"
      ],
      "dependsOrder": "sequence"
    },

    {
      "label": "buildapp",
      "type": "shell",
      "command": "make",
      "options": {
        "cwd": "${workspaceFolder}/cmake"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },

    {
      "label": "buildrcge",
      "type": "shell",
      "command": "make",
      "options": {
        "cwd": "${workspaceFolder}/libs/rcge/cmake"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "dependsOn": [
        "builddocs",
      ],
      "dependsOrder": "sequence"
    },

    {
      "label": "builddocs",
      "type": "shell",  
      "command": "doxygen docs/settings/Doxyfile",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ]
}