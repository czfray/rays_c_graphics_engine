{
  "version": "1.0.0",
  "configurations": [
    {
      "name": "Debug Run App",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/appdb",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "buildappdb",
      "externalConsole": false
    },

    {
      "name": "Build RGCE and Debug Run App",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/appdb",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "buildappdb+rgce",
      "externalConsole": false
    },

    {
      "name": "Build App",
      "type": "cppdbg",
      "request": "launch",
      "program": "${env:ComSpec}",
      "args": ["/c", "exit"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "buildapp",
      "externalConsole": false
    },

    {
      "name": "Build RCGE",
      "type": "cppdbg",
      "request": "launch",
      "program": "${env:ComSpec}",
      "args": ["/c", "exit"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "cleanbuildrcge",
      "externalConsole": false
    },

    {
      "name": "Build Docs",
      "type": "cppdbg",
      "request": "launch",
      "program": "${env:ComSpec}",
      "args": ["/c", "exit"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "builddocs",
      "externalConsole": false
    }
  ]
}
