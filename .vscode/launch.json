{
  "version": "1.0.0",
  "configurations": [
    {
      "name": "Debug Run App",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/app_debug",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "buildappdb",
      "externalConsole": true
    },

    {
      "name": "Build RGCE and Debug Run App",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/app_debug",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "buildappdb+rgce",
      "externalConsole": true
    },

    {
      "name": "Build App",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${env:ComSpec}",
      "args": ["/c", "exit"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "buildapp",
      "externalConsole": false
    },

    {
      "name": "Build RCGE",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${env:ComSpec}",
      "args": ["/c", "exit"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "buildrcge",
      "externalConsole": false
    },

    {
      "name": "Build Docs",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${env:ComSpec}",
      "args": ["/c", "exit"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "builddocs",
      "externalConsole": false
    }
  ]
}
